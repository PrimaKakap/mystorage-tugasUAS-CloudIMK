generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activity_logs {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt?
  action     String?   @db.VarChar(100)
  file_id    BigInt?
  folder_id  BigInt?
  created_at DateTime? @default(now()) @db.Timestamp(0)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "activity_logs_ibfk_1")

  @@index([user_id], map: "user_id")
}

model file_shares {
  id         BigInt    @id @default(autoincrement())
  file_id    BigInt?
  token      String?   @db.VarChar(255)
  expired_at DateTime? @db.DateTime(0)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  files      files?    @relation(fields: [file_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "file_shares_ibfk_1")

  @@index([file_id], map: "file_id")
}

model files {
  id            BigInt        @id @default(autoincrement())
  folder_id     BigInt?
  owner_id      BigInt
  original_name String        @db.VarChar(255)
  storage_name  String        @db.VarChar(255)
  extension     String?       @db.VarChar(20)
  mime_type     String?       @db.VarChar(100)
  file_size     BigInt
  storage_path  String        @db.VarChar(500)
  bucket_name   String?       @db.VarChar(100)
  is_starred    Boolean?      @default(false)
  is_deleted    Boolean?      @default(false)
  created_at    DateTime?     @default(now()) @db.Timestamp(0)
  updated_at    DateTime?     @default(now()) @db.Timestamp(0)
  file_shares   file_shares[]
  folders       folders?      @relation(fields: [folder_id], references: [id], onUpdate: NoAction, map: "files_ibfk_1")
  users         users         @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "files_ibfk_2")

  @@index([folder_id], map: "folder_id")
  @@index([owner_id], map: "owner_id")
}

model folders {
  id            BigInt    @id @default(autoincrement())
  owner_id      BigInt
  parent_id     BigInt?
  folder_name   String    @db.VarChar(150)
  color         String?   @default("#FFD54F") @db.VarChar(30)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
  files         files[]
  users         users     @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "folders_ibfk_1")
  folders       folders?  @relation("foldersTofolders", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "folders_ibfk_2")
  other_folders folders[] @relation("foldersTofolders")

  @@index([owner_id], map: "owner_id")
  @@index([parent_id], map: "parent_id")
}

model storage_usage {
  id            BigInt  @id @default(autoincrement())
  user_id       BigInt?
  total_storage BigInt? @default(107374182400)
  used_storage  BigInt? @default(0)
  users         users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "storage_usage_ibfk_1")

  @@index([user_id], map: "user_id")
}

model users {
  id            BigInt          @id @default(autoincrement())
  fullname      String          @db.VarChar(150)
  email         String          @unique(map: "email") @db.VarChar(150)
  password      String          @db.VarChar(255)
  photo         String?         @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamp(0)
  updated_at    DateTime?       @default(now()) @db.Timestamp(0)
  activity_logs activity_logs[]
  files         files[]
  folders       folders[]
  storage_usage storage_usage[]
}
